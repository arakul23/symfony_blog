{% extends 'layout.html.twig' %}

{% block title %}Blog index{% endblock %}

{% block body %}
    <h1>Blog index</h1>

    {{ form_start(searchForm) }}
    {{ form_widget(searchForm) }}
    <button class="btn">{{ button_label|default('Find') }}</button>
    {{ form_end(searchForm) }}


    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Title</th>
                <th>Owner</th>
                <th>Description</th>
                <th>Text</th>
                <th>Percent</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for blog in blogs %}
            <tr>
                <td>{{ blog.id }}</td>
                <td>{{ blog.title }}</td>
                <td>{{ blog.user.email ?? '' }}</td>
                <td>{{ blog.description }}</td>
                <td>{{ blog.text }}</td>
                <td>{{ blog.percent }}</td>
                <td>
                    <a href="{{ path('app_user_blog_show', {'id': blog.id}) }}">show</a>
                    <a href="{{ path('app_user_blog_edit', {'id': blog.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="5">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <div class="navigation">
        {{ knp_pagination_render(blogs) }}
    </div>

    {% if is_granted('ROLE_ADMIN') %}
    <a href="{{ path('app_blog_new') }}">Create new</a>
    {% else %}
        <a href="{{ path('app_user_blog_new') }}">Create new</a>
    {% endif %}
{% endblock %}
